<Window x:Class="pr_24._106_pavlenko_2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вариант 2" Height="400" Width="500"
        WindowStartupLocation="CenterScreen">
    <StackPanel Margin="15">
        <TextBlock Text="Павленко" FontSize="14" Margin="0,0,0,5"/>
        <TextBlock Text="Вариант 2" FontSize="14" Margin="0,0,0,15"/>

        <TextBlock Text="Введите предложение (на английском):" FontSize="14"/>
        <TextBox x:Name="InputTextBox" Height="30" FontSize="14" Margin="0,5,0,15"/>
        <Button x:Name="CalculateButton" Padding="10" FontSize="14" Width="120" HorizontalAlignment="Left" Click="CalculateButton_Click">
            <Label Content="Посчитать"/>
        </Button>

        <TextBlock Text="Количество гласных:" FontSize="14" Margin="0,20,0,0"/>
        <TextBlock x:Name="VowelCountTextBlock" Text="—" FontSize="16" Margin="0,5,0,10"/>

        <TextBlock Text="Самое длинное слово:" FontSize="14"/>
        <TextBlock x:Name="LongestWordTextBlock" Text="—" FontSize="16"  Margin="0,5,0,0"/>
    </StackPanel>
</Window>